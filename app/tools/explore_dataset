import pandas as pd

print('Chargement en cours...')

df_09 = pd.read_excel('data/online_retail_II.xlsx', sheet_name='Year 2009-2010')
df_10 = pd.read_excel('data/online_retail_II.xlsx', sheet_name='Year 2010-2011')
df    = pd.concat([df_09, df_10], ignore_index=True)

print(f'Lignes totales   : {len(df):,}')
print(f'Colonnes         : {list(df.columns)}')

for col in df.columns:
    nulls = df[col].isnull().sum()
    pct   = round(nulls / len(df) * 100, 1)
    print(f'  {col:15} | manquants: {nulls:,} ({pct}%)')

cancels   = df[df['Invoice'].astype(str).str.startswith('C')]
neg_qty   = df[df['Quantity'] < 0]
bad_price = df[df['Price'] <= 0]

print(f'Annulations : {len(cancels):,}')
print(f'Qty neg     : {len(neg_qty):,}')
print(f'Prix nuls   : {len(bad_price):,}')

df.to_csv('data/online_retail_II.csv', index=False)
print('CSV sauvegarde !')
